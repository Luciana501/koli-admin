# KOLI Presale Admin Panel - Environment
# No secrets needed — everything runs client-side with Phantom wallet

# Optional: Override RPC endpoint for better performance
# NEXT_PUBLIC_RPC_ENDPOINT=https://api.devnet.solana.com

# Optional: Known admin public key (for display purposes)
# NEXT_PUBLIC_ADMIN_PUBKEY=YOUR_ADMIN_PUBKEY_HERE

# Firebase Admin SDK (required for /api/kash-cashouts/*)
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional: restrict browser origin allowed to call cashout routes
# CASHOUT_ALLOWED_ORIGIN=http://localhost:8080
